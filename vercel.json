{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix client",
  "buildCommand": "npm run build",
  "functions": {
    "app.js": {
      "includeFiles": "client/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app"
    }
  ]
}
